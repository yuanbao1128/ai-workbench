{
  "crons": [
    { "path": "/api/cron/check-reminders", "schedule": "0 10 * * *" },
    { "path": "/api/cron/daily-report", "schedule": "0 18 * * 1-5" },
    { "path": "/api/cron/weekly-report", "schedule": "0 18 * * 5" },
    { "path": "/api/cron/morning-brief", "schedule": "0 9 * * 1-5" }
  ],
  "headers": [
    {
      "source": "/api/(knowledge|tasks|legacy-issues|delegation|reports)(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, stale-while-revalidate=60, s-maxage=30" }
      ]
    }
  ]
}