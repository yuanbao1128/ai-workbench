# Database (Supabase PostgreSQL)
# Replace with your actual Supabase connection string after creating a Supabase project
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# AI Provider (anthropic | openai | custom)
AI_PROVIDER="openai"

# OpenAI API Key (if using OpenAI)
OPENAI_API_KEY="sk-proj-your-openai-key-here"

# Anthropic API Key (if using Anthropic)
ANTHROPIC_API_KEY="sk-ant-api03-your-anthropic-key-here"

# AI Model (depends on provider)
AI_MODEL="gpt-4o"

# Custom API Base URL (only if AI_PROVIDER=custom)
AI_BASE_URL=""

# Cron Job Secret (for securing cron endpoints)
CRON_SECRET="your-cron-secret-here"

# Web Push VAPID Keys (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:your-email@example.com"