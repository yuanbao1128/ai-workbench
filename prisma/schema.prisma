// Prisma Schema for AI 工作台
// Uses String instead of enum for PostgreSQL compatibility

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Models
// ============================================================

model Card {
  id           String   @id @default(cuid())
  title        String
  type         String   @default("TERM")
  status       String   @default("UNKNOWN")
  content      String?
  keyConcepts  String   @default("[]")
  relatedCards String   @default("[]")
  source       String?
  history      String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Task {
  id           String   @id @default(cuid())
  title        String
  type         String   @default("SCHEDULE")
  priority     String   @default("NORMAL")
  status       String   @default("PENDING")
  dueDate      DateTime?
  relatedCards String   @default("[]")
  createdAt    DateTime @default(now())
  completedAt  DateTime?
}

model LegacyIssue {
  id          String   @id @default(cuid())
  title       String
  plannedDate DateTime?
  status      String   @default("PENDING")
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
}

model Delegation {
  id             String   @id @default(cuid())
  title          String
  assignee       String
  source         String?
  status         String   @default("WAITING")
  priority       String   @default("NORMAL")
  followUpTimes  String   @default("[]")
  customFollowUp String?
  conclusion     String?
  timeline       String   @default("[]")
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  description String
  refId       String?
  refType     String?
  timestamp   DateTime @default(now())
}

model Report {
  id         String   @id @default(cuid())
  type       String
  dateRange  String
  content    String
  weekNumber Int?
  createdAt  DateTime @default(now())
}

model Setting {
  id          String   @id @default("app-settings")
  apiProvider String   @default("anthropic")
  apiKey      String   @default("")
  model       String   @default("claude-sonnet-5")
  baseUrl     String?
  updatedAt   DateTime @updatedAt
}